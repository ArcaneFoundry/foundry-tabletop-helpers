<div class="cc-class-choices" data-step="classChoices">
  <div class="cc-step-intro">
    <p>Choose the class skills that round out your <strong><u>{{className}}</u></strong> before moving into background and origin details.</p>
    {{#if primaryAbilityHint}}
    <p><strong>Prime Attribute Guidance:</strong> {{primaryAbilityHint}}</p>
    {{/if}}
  </div>

  <section class="cc-panel cc-choice-section cc-choice-section--skills">
    <div class="cc-choice-section__header">
      <div class="cc-choice-section__heading">
        <h3>Class Skills</h3>
        <p>Choose the skills this class teaches from the outset.</p>
      </div>
      <div class="cc-choice-section__status">
        <div class="cc-skills__counter">
          <span class="cc-skills__count" data-choice-count="skills">{{skillSection.chosenCount}}</span>
          <span class="cc-skills__sep">/</span>
          <span class="cc-skills__max">{{skillSection.maxCount}}</span>
          <span class="cc-skills__counter-label">selected</span>
        </div>
        <div class="cc-choice-section__selected" data-selected-chips="skills">
          {{#each skillSection.selectedEntries}}
          <span class="cc-choice-chip">
            <i class="fa-solid {{iconClass}}"></i>
            <span>{{label}}</span>
          </span>
          {{/each}}
        </div>
      </div>
    </div>

    {{#if skillSection.hasChoices}}
    <div class="cc-choice-grid cc-choice-grid--skills">
      {{#each skillSection.options}}
      <label class="cc-choice-option{{#if checked}} cc-choice-option--selected{{/if}}">
        <input
          type="checkbox"
          class="cc-choice-option__checkbox"
          data-choice-section="skills"
          data-choice-value="{{key}}"
          data-choice-label="{{label}}"
          {{#if checked}}checked{{/if}}
          {{#if disabled}}disabled{{/if}}>
        <div class="cc-choice-option__icon">
          <i class="fa-solid {{iconClass}}"></i>
        </div>
        <div class="cc-choice-option__body">
          <div class="cc-choice-option__title-row">
            <span class="cc-choice-option__title">{{label}}</span>
            <span class="cc-choice-option__meta">{{abilityAbbrev}}</span>
          </div>
          <p class="cc-choice-option__copy">{{tooltip}}</p>
        </div>
      </label>
      {{/each}}
    </div>
    {{else}}
    <p class="cc-card-detail__hint">{{skillSection.emptyMessage}}</p>
    {{/if}}
  </section>
</div>
