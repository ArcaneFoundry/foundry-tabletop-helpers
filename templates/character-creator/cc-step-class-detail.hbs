{{#if selectedEntry}}
<div class="cc-class-detail-shell">
  <div class="cc-class-detail__ornament" aria-hidden="true">
    <i class="fa-solid fa-dice-d20 cc-class-detail__ornament-die cc-class-detail__ornament-die--primary"></i>
    <i class="fa-solid fa-dice-d10 cc-class-detail__ornament-die cc-class-detail__ornament-die--mid"></i>
    <i class="fa-solid fa-dice-d6 cc-class-detail__ornament-die cc-class-detail__ornament-die--small"></i>
  </div>

  <button class="cc-class-detail-summary" type="button" data-class-detail-toggle aria-label="Expand class details">
    <div class="cc-class-detail-summary__thumb">
      <img src="{{selectedEntry.heroImg}}" alt="{{selectedEntry.name}}">
    </div>

    <div class="cc-class-detail-summary__body">
      <div class="cc-class-detail-summary__header">
        <div>
          <h3 class="cc-class-detail-summary__title">{{selectedEntry.name}}</h3>
          <p class="cc-class-detail-summary__subtitle">Level {{selectedEntry.startingLevel}} • {{selectedEntry.packLabel}}</p>
        </div>
        <div class="cc-class-detail-summary__metrics">
          <span class="cc-class-detail-summary__metric">Hit Die: {{selectedEntry.hitDie}}</span>
        </div>
      </div>

      <p class="cc-class-detail-summary__blurb">{{selectedEntry.subtitle}}</p>

      {{#if selectedEntry.hasPrimaryAbilities}}
      <div class="cc-class-detail-summary__facts">
        <span class="cc-class-detail-summary__fact">
          <i class="fa-solid fa-star" aria-hidden="true"></i>
          <span><strong>Primary Ability:</strong> {{selectedEntry.primaryAbilityText}}</span>
        </span>
        {{#if selectedEntry.armorSummary}}<span class="cc-class-detail-summary__fact"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i><span><strong>Armor:</strong> {{selectedEntry.armorSummary}}</span></span>{{/if}}
        {{#if selectedEntry.weaponSummary}}<span class="cc-class-detail-summary__fact"><i class="fa-solid fa-swords" aria-hidden="true"></i><span><strong>Weapons:</strong> {{selectedEntry.weaponSummary}}</span></span>{{/if}}
      </div>
      {{/if}}
    </div>
  </button>

  <section class="cc-class-detail-expanded">
    <button class="cc-class-detail-expanded__close" type="button" data-class-detail-close aria-label="Collapse class details">
      <i class="fa-solid fa-xmark"></i>
      <span>Close</span>
    </button>

    <div class="cc-class-detail-expanded__layout">
      <div class="cc-class-detail-expanded__hero">
        <img src="{{selectedEntry.heroImg}}" alt="{{selectedEntry.name}}">
      </div>

      <div class="cc-class-detail-expanded__content">
        <div class="cc-class-detail-expanded__header">
          <div>
            <h3 class="cc-class-detail-expanded__title">{{selectedEntry.name}}</h3>
            <p class="cc-class-detail-expanded__subtitle">Level {{selectedEntry.startingLevel}} • {{selectedEntry.packLabel}}</p>
          </div>
          <div class="cc-class-detail-expanded__metrics">
            <span class="cc-class-detail-expanded__metric">Hit Die: {{selectedEntry.hitDie}}</span>
            <span class="cc-class-detail-expanded__metric">HP: {{selectedEntry.hitPointsAtFirstLevel}}</span>
          </div>
        </div>

        <div class="cc-class-detail-expanded__blurb">
          <p>{{selectedEntry.subtitle}}</p>
          {{#if selectedEntry.hasPrimaryAbilities}}
          <p class="cc-class-detail-expanded__lead-fact"><i class="fa-solid fa-star" aria-hidden="true"></i><span><strong>Primary Ability:</strong> {{selectedEntry.primaryAbilityText}}</span></p>
          {{/if}}
        </div>

        <div class="cc-class-detail-expanded__proficiencies">
          {{#if selectedEntry.armorSummary}}
          <div class="cc-class-detail-expanded__prof-group">
            <div class="cc-class-detail-expanded__prof-label"><i class="fa-solid fa-shield-halved" aria-hidden="true"></i><span>Armor</span></div>
            <div class="cc-class-detail-expanded__prof-value">{{selectedEntry.armorSummary}}</div>
          </div>
          {{/if}}

          {{#if selectedEntry.weaponSummary}}
          <div class="cc-class-detail-expanded__prof-group">
            <div class="cc-class-detail-expanded__prof-label"><i class="fa-solid fa-swords" aria-hidden="true"></i><span>Weapons</span></div>
            <div class="cc-class-detail-expanded__prof-value">{{selectedEntry.weaponSummary}}</div>
          </div>
          {{/if}}

          {{#if selectedEntry.hasSavingThrows}}
          <div class="cc-class-detail-expanded__prof-group">
            <div class="cc-class-detail-expanded__prof-label"><i class="fa-solid fa-dice-d20" aria-hidden="true"></i><span>Saving Throws</span></div>
            <div class="cc-class-detail-expanded__prof-value">{{selectedEntry.savingThrowsSummary}}</div>
          </div>
          {{/if}}
        </div>

        {{#if selectedEntry.hasFeatures}}
        <div class="cc-class-detail-expanded__abilities">
          <div class="cc-class-detail-expanded__abilities-label"><i class="fa-solid fa-wand-sparkles" aria-hidden="true"></i><span>{{selectedEntry.featureHeading}}</span></div>
          <ul class="cc-class-detail-expanded__abilities-list">
            {{#each selectedEntry.classFeatures}}
            <li class="cc-class-detail-expanded__abilities-item">{{displayLabel}}</li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
      </div>
    </div>
  </section>
</div>
{{else}}
<div class="cc-card-detail cc-card-detail--empty cc-class-detail--empty">
  <div class="cc-class-detail__ornament" aria-hidden="true">
    <i class="fa-solid fa-dice-d20 cc-class-detail__ornament-die cc-class-detail__ornament-die--primary"></i>
    <i class="fa-solid fa-dice-d10 cc-class-detail__ornament-die cc-class-detail__ornament-die--mid"></i>
    <i class="fa-solid fa-dice-d6 cc-class-detail__ornament-die cc-class-detail__ornament-die--small"></i>
  </div>
  <div class="cc-card-detail__empty-icon">
    <i class="fa-solid fa-shield-halved"></i>
  </div>
  <div class="cc-card-detail__empty-copy">
    <p class="cc-card-detail__empty-title">Class details will appear here</p>
    <p class="cc-card-detail__empty-text">Choose the class that will shape your legend. Its talents, battle doctrine, and signature features will gather here.</p>
  </div>
</div>
{{/if}}
