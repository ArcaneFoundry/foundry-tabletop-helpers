{{#if selectedEntry}}
<div class="cc-class-spotlight cc-class-spotlight--active">
  <div class="cc-class-spotlight__bg" style="background-image: url('{{selectedEntry.heroImg}}');"></div>
  <div class="cc-class-spotlight__overlay"></div>

  <div class="cc-class-spotlight__content">
    <section class="cc-class-spotlight__hero-card">
      <div class="cc-class-spotlight__crest">
        <img class="cc-class-spotlight__crest-img" src="{{selectedEntry.img}}" alt="{{selectedEntry.name}}">
      </div>
      <div class="cc-class-spotlight__title-block">
        <div class="cc-class-spotlight__eyebrow">{{selectedEntry.packLabel}}</div>
        <h3 class="cc-class-spotlight__title">{{selectedEntry.name}}</h3>
        <p class="cc-class-spotlight__subtitle">{{selectedEntry.subtitle}}</p>
      </div>
    </section>

    <div class="cc-class-spotlight__scroll">
      <section class="cc-class-spotlight__panel cc-class-spotlight__panel--metrics">
        <div class="cc-class-spotlight__metric">
          <span class="cc-class-spotlight__metric-label">Hit Die</span>
          <span class="cc-class-spotlight__metric-value">{{selectedEntry.hitDie}}</span>
        </div>
        <div class="cc-class-spotlight__metric">
          <span class="cc-class-spotlight__metric-label">Level 1 HP</span>
          <span class="cc-class-spotlight__metric-value">{{selectedEntry.hitPointsAtFirstLevel}}</span>
        </div>
        <div class="cc-class-spotlight__metric">
          <span class="cc-class-spotlight__metric-label">Spellcasting</span>
          <span class="cc-class-spotlight__metric-value">{{selectedEntry.spellcastingSummary}}</span>
        </div>
      </section>

      {{#if selectedEntry.hasPrimaryAbilities}}
      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Prime Attributes</h4>
        <p class="cc-class-spotlight__panel-copy"><strong>{{selectedEntry.primaryAbilityText}}</strong> — {{selectedEntry.primaryAbilityHint}}</p>
      </section>
      {{/if}}

      {{#if selectedEntry.hasSavingThrows}}
      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Saving Throw Training</h4>
        <div class="cc-chip-row">
          {{#each selectedEntry.savingThrowProficiencies}}
          <span class="cc-chip">{{this}}</span>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if selectedEntry.hasArmorProficiencies}}
      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Armor Training</h4>
        <div class="cc-chip-row">
          {{#each selectedEntry.armorProficiencies}}
          <span class="cc-chip">{{this}}</span>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{#if selectedEntry.hasWeaponProficiencies}}
      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Weapon Training</h4>
        <div class="cc-chip-row">
          {{#each selectedEntry.weaponProficiencies}}
          <span class="cc-chip">{{this}}</span>
          {{/each}}
        </div>
      </section>
      {{/if}}

      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Battle Doctrine</h4>
        <div class="cc-chip-row">
          {{#if selectedEntry.hasWeaponMastery}}
          <span class="cc-chip">Weapon Mastery</span>
          {{else}}
          <span class="cc-chip">No Weapon Mastery</span>
          {{/if}}
          {{#if selectedEntry.isSpellcaster}}
          <span class="cc-chip">Spellcasting</span>
          {{else}}
          <span class="cc-chip">Steel and skill first</span>
          {{/if}}
        </div>
      </section>

      {{#if selectedEntry.hasFeatures}}
      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">{{selectedEntry.featureHeading}}</h4>
        <ul class="cc-class-spotlight__feature-list">
          {{#each selectedEntry.classFeatures}}
          <li class="cc-class-spotlight__feature-item">{{displayLabel}}</li>
          {{/each}}
        </ul>
      </section>
      {{/if}}

      <section class="cc-class-spotlight__panel">
        <h4 class="cc-class-spotlight__panel-title">Class Overview</h4>
        {{#if selectedEntry.hasDescription}}
        <div class="cc-card-detail__description">{{{selectedEntry.description}}}</div>
        {{else}}
        <p class="cc-class-spotlight__panel-copy">No compendium description is available for this class yet.</p>
        {{/if}}
      </section>
    </div>
  </div>
</div>
{{else}}
<div class="cc-card-detail cc-card-detail--empty cc-class-detail--empty">
  <div class="cc-card-detail__empty-icon">
    <i class="fa-solid fa-sparkles"></i>
  </div>
  <p class="cc-card-detail__empty-text">Choose the class that will shape your legend. Its talents, battle doctrine, and signature features will gather here.</p>
</div>
{{/if}}
