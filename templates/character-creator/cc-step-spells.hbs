{{!-- Character Creator — Spells Step --}}
<div class="cc-spells-step" data-step="spells">

  {{!-- Search Bar --}}
  <div class="cc-spells-search">
    <i class="fa-solid fa-magnifying-glass"></i>
    <input type="text"
           class="cc-spells-search__input"
           data-spell-search
           placeholder="Search spells..."
           autocomplete="off">
  </div>

  {{!-- Cantrips Section --}}
  {{#if hasCantrips}}
  <div class="cc-spell-section">
    <div class="cc-spell-section__header">
      <h3 class="cc-spell-section__title">
        <i class="fa-solid fa-fire"></i>
        Cantrips
      </h3>
      <span class="cc-spell-section__count" data-cantrip-limit="{{maxCantrips}}">
        {{#if maxCantrips}}{{cantripCount}} / {{maxCantrips}} selected{{else}}{{cantripCount}} selected{{/if}}
      </span>
    </div>
    <div class="cc-spell-grid">
      {{#each cantrips}}
      <div class="cc-spell-card{{#if selected}} cc-spell-card--selected{{/if}}"
           data-cantrip-uuid="{{uuid}}"
           data-spell-name="{{name}}"
           role="button"
           tabindex="0"
           aria-selected="{{selected}}"
           style="--cc-card-index: {{@index}}">
        <div class="cc-spell-card__img-wrap">
          <img class="cc-spell-card__img" src="{{img}}" alt="{{name}}" loading="lazy">
        </div>
        <div class="cc-spell-card__info">
          <div class="cc-spell-card__name">{{name}}</div>
          <div class="cc-spell-card__school">{{schoolLabel}}</div>
        </div>
        {{#if selected}}
        <div class="cc-spell-card__check">
          <i class="fa-solid fa-check"></i>
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- Leveled Spells by Level --}}
  {{#if hasSpells}}
  {{#each spellsByLevel}}
  <div class="cc-spell-section">
    <div class="cc-spell-section__header">
      <h3 class="cc-spell-section__title">
        <i class="fa-solid fa-book-open"></i>
        {{label}}
      </h3>
    </div>
    <div class="cc-spell-grid">
      {{#each spells}}
      <div class="cc-spell-card{{#if selected}} cc-spell-card--selected{{/if}}"
           data-spell-uuid="{{uuid}}"
           data-spell-name="{{name}}"
           role="button"
           tabindex="0"
           aria-selected="{{selected}}"
           style="--cc-card-index: {{@index}}">
        <div class="cc-spell-card__img-wrap">
          <img class="cc-spell-card__img" src="{{img}}" alt="{{name}}" loading="lazy">
        </div>
        <div class="cc-spell-card__info">
          <div class="cc-spell-card__name">{{name}}</div>
          <div class="cc-spell-card__school">{{schoolLabel}}</div>
        </div>
        {{#if selected}}
        <div class="cc-spell-card__check">
          <i class="fa-solid fa-check"></i>
        </div>
        {{/if}}
        {{#if ../../showPreparedPicker}}
        <button class="cc-spell-card__prep-toggle{{#if prepared}} cc-spell-card__prep-toggle--active{{/if}}"
                type="button"
                data-prepared-uuid="{{uuid}}"
                {{#unless selected}}disabled{{/unless}}>
          {{#if prepared}}Prepared{{else}}Prepare{{/if}}
        </button>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/each}}
  {{/if}}

  {{!-- Empty State --}}
  {{#unless hasCantrips}}
  {{#unless hasSpells}}
  <div class="cc-empty-state">
    <i class="fa-solid fa-wand-sparkles"></i>
    <p>No spells found for {{className}}. Check your compendium source configuration.</p>
  </div>
  {{/unless}}
  {{/unless}}

  {{!-- Filter notice --}}
  {{#unless usingClassFilter}}
  {{#if hasSpells}}
  <div class="cc-spells-notice">
    <i class="fa-solid fa-circle-info"></i>
    <span>Showing all available spells. Select spells appropriate for your {{className}}.</span>
  </div>
  {{/if}}
  {{/unless}}

  {{#if hasPreparationNotice}}
  <div class="cc-spells-notice">
    <i class="fa-solid fa-circle-info"></i>
    <span>{{preparationNotice}}</span>
  </div>
  {{/if}}

  <div class="cc-spells-summary">
    <span class="cc-spells-summary__label">Selected:</span>
    <span class="cc-spells-summary__value"
          data-cantrip-limit="{{maxCantrips}}"
          data-spell-limit="{{maxSpells}}"
          data-prepared-limit="{{preparedLimit}}">
      {{selectionSummary}}
    </span>
  </div>

  {{#if showPreparedPicker}}
  <div class="cc-spells-summary" data-prepared-picker="true">
    <span class="cc-spells-summary__label">Prepared:</span>
    <span class="cc-spells-summary__value">{{preparedCount}} / {{preparedLimit}} spells</span>
  </div>
  {{/if}}

</div>
