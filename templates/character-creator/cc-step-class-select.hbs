<div class="cc-class-select{{#if selectedEntry}} cc-class-select--has-selection{{/if}}" data-step="{{stepId}}">
  {{#if hasEntries}}
  <header class="cc-class-select__titlebar">
    <div class="cc-class-select__title-wrap">
      <span class="cc-class-select__title-cap cc-class-select__title-cap--left" aria-hidden="true"></span>
      <h2 class="cc-class-select__title">Choose Your Class</h2>
      <span class="cc-class-select__title-cap cc-class-select__title-cap--right" aria-hidden="true"></span>
    </div>
  </header>

  <div class="cc-card-select__grid-pane cc-class-select__cards-scroll">
      <div class="cc-card-grid">
        {{#each entries}}
        <div class="cc-select-card cc-select-card--class{{#if selected}} cc-select-card--selected{{/if}}"
             data-card-uuid="{{uuid}}"
             role="button"
             tabindex="0"
             aria-selected="{{selected}}"
             style="--cc-card-index: {{@index}}">
          <div class="cc-select-card__img-wrap">
            <img class="cc-select-card__img" src="{{cardImg}}" alt="{{name}}" loading="lazy">
          </div>
          <div class="cc-select-card__info">
            <div class="cc-select-card__name">{{name}}</div>
          </div>
          {{#if selected}}
          <div class="cc-select-card__check">
            <i class="fa-solid fa-check"></i>
          </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
  </div>

  <div class="cc-card-detail-pane cc-class-select__detail-pane">{{{detailPaneHtml}}}</div>
  {{else}}
  <div class="cc-empty-state">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <p>{{emptyMessage}}</p>
  </div>
  {{/if}}
</div>
