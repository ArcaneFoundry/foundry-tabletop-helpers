{
  "name": "foundry-tabletop-helpers",
  "version": "1.2.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "npm run typecheck && vite build && node scripts/build-manifest.mjs",
    "dev": "vite build --watch",
    "ci": "npm run typecheck && npm run test && npm run build",
    "build:server": "cd server-companion && npm run build",
    "package:server": "cd server-companion && npm run package",
    "zip": "npm run build && cd dist && zip -r ../foundry-tabletop-helpers.zip .",
    "tarball": "npm run build && mkdir -p build && tar -czvf build/foundry-tabletop-helpers-dev.tar.gz -C dist .",
    "link:foundry": "node scripts/link-foundry.mjs"
  },
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "^13.346.0-beta.20250812191140",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.2.0",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0",
    "vite": "^8.0.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "motion": "^12.37.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  }
}
